{
  "name": "lounge-translation-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Daily Japanese-English translation practice tracker for瞬間英作文 learning from YouTube",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "pages:dev": "wrangler pages dev dist --compatibility-date=2024-01-01 --d1 DB=lounge-translation-db",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "db:create": "wrangler d1 create lounge-translation-db",
    "db:migrate": "wrangler d1 execute lounge-translation-db --file=./schema.sql"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.90.0"
  }
}
